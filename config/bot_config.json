{
  "slug": "my-custom-bot",
  "bot_name": "내 챗봇",
  "preset": "custom",
  "description": "본인 목적에 맞춰 자유롭게 구성한 챗봇",
  "frontend": "streamlit",
  "model_name": "gpt-4o-mini",
  "embedding_model": "text-embedding-3-small",
  "chunk_size": 900,
  "chunk_overlap": 120,
  "retrieval_strategy": "hybrid_rerank",
  "top_k": 5,
  "llm_rerank": true,
  "use_memory": true,
  "memory_turns": 6,
  "system_prompt": "너는 사용자가 정의한 챗봇이다. 아래 지침을 따른다.\r\n\r\n- (여기에 챗봇의 역할·말투·답변 원칙을 자유롭게 적어주세요)\r\n- 업로드된 문서가 있으면 우선 근거로 사용하고, 없는 내용은 모른다고 답한다.\r\n- 한국어로 답한다.",
  "output_template": "💬 답변\r\n{answer}\r\n\r\n📚 근거\r\n{sources}",
  "enable_agent": false,
  "enable_stock_tool": false,
  "enable_company_info": false,
  "enable_financials": false,
  "enable_news_search": false,
  "enable_calorie_tool": false,
  "enable_calculator_tool": true,
  "enable_vision": false,
  "enable_graphrag": false,
  "enable_voice": true,
  "voice_name": "alloy",
  "multi_agent_mode": false,
  "telegram_enabled": false,
  "yahoo_provider": "yfinance",
  "cite_sources": true,
  "allow_general_knowledge": false,
  "show_debug_context": false
}